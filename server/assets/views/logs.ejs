<!DOCTYPE html>
<html lang="<%= locale %>">

<% include partials/head_i18n.ejs %>


<body>
    <div class="ui container">
        <% include partials/header_i18n.ejs %>
        <% include partials/disclaimer.ejs %>
        <div style="text-align: right; padding: 10px;">
            <a href="?lang=<%= locale === 'en' ? 'zh' : 'en' %>" class="ui basic small button">
                🌐 <%= locale === 'en' ? '简体中文' : 'English' %>
            </a>
        </div> 
        <div class="ui segment">
            <div class="logs">
                <% logs.forEach((log) => { %>
                <div class="logitm <%= log.type %>">
                    <%= new Date(log.time).toLocaleString('en-GB', { timeZone: 'UTC' }) %> =>
                    <%= log.type %> | <%= log.message %> </div>
                <% }) %>
            </div>
        </div>
    </div>
    <% include partials/footer.ejs %>
</body>

</html>